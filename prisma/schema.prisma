generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
// MULTI-TENANT CORE
// ═══════════════════════════════════════════════

model Organization {
  id        String   @id @default(cuid())
  name      String                          // "Casagrande & Rocha"
  slug      String   @unique               // "casagrande-rocha"
  cnpj      String   @default("")
  phone     String   @default("")
  email     String   @default("")
  city      String   @default("")
  state     String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  clients       Client[]
  taskLists     TaskList[]
  teamGroups    TeamGroup[]
  billings      Billing[]
  aiUsage       AiUsage[]
  subscriptions OrgSubscription[]

  @@map("organizations")
}

model Product {
  id           String   @id @default(cuid())
  name         String   @unique             // "BitTask App", "BitTask AI"
  slug         String   @unique             // "app", "ai"
  description  String   @default("")
  monthlyPrice Float    @default(0)         // 49.90, 29.90
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  subscriptions OrgSubscription[]

  @@map("products")
}

model OrgSubscription {
  id        String    @id @default(cuid())
  orgId     String
  productId String
  isActive  Boolean   @default(true)
  startDate DateTime  @default(now())
  endDate   DateTime?

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])

  @@unique([orgId, productId])
  @@map("org_subscriptions")
}

model Billing {
  id          String    @id @default(cuid())
  orgId       String
  month       String                         // "2026-04"
  baseAmount  Float     @default(0)          // Produtos ativos
  overage     Float     @default(0)          // Excedente AI do mês anterior
  totalAmount Float     @default(0)
  status      String    @default("nao_gerado") // nao_gerado, aguardando, pago, erro
  asaasId     String    @default("")         // ID da cobrança no Asaas
  paymentLink String    @default("")
  paidAt      DateTime?
  generatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, month])
  @@index([status])
  @@map("billings")
}

model AiUsage {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  month     String                            // "2026-04"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, month])
  @@map("ai_usage")
}

model Invite {
  id        String    @id @default(cuid())
  orgId     String
  email     String
  role      String    @default("agent")      // "admin" ou "agent"
  token     String    @unique @default(cuid())
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([orgId])
  @@map("invites")
}

// ═══════════════════════════════════════════════
// USERS & AUTH
// ═══════════════════════════════════════════════

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String
  password          String
  phone             String   @default("")
  notificationEmail String   @default("")
  orgId             String?
  userRole          String   @default("agent") // "super_admin", "admin", "agent"
  position          String   @default("")      // Custom job title: "Supervisor", "Analista", etc.
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  org               Organization? @relation(fields: [orgId], references: [id])
  simulations       Simulation[]
  sharedSimulations SimulationShare[]
  clients           Client[]
  taskLists         TaskList[]
  createdTasks      Task[]   @relation("TaskCreator")
  assignedTasks     Task[]   @relation("TaskAssignee")
  negotiations      Negotiation[] @relation("NegotiationAssignee")
  teamGroups        TeamGroupMember[]
  googleCalendarToken GoogleCalendarToken?
  comments      NegotiationComment[]
  goals         UserGoal[]
  auditLogs     AuditLog[]

  @@index([orgId])
  @@map("users")
}

// ═══════════════════════════════════════════════
// TASKS
// ═══════════════════════════════════════════════

model TaskList {
  id        String   @id @default(cuid())
  name      String
  userId    String
  orgId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  org   Organization? @relation(fields: [orgId], references: [id])
  tasks Task[]

  @@index([userId])
  @@index([orgId])
  @@map("task_lists")
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  completed   Boolean  @default(false)
  date        String   @default("")
  time        String   @default("")
  dueDate     String   @default("")
  starred     Boolean  @default(false)
  scheduled   Boolean  @default(false)
  priority    String   @default("medium")
  googleCalendarEventId String @default("")
  listId      String
  createdById String
  assigneeId  String?
  groupId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  list      TaskList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdBy User          @relation("TaskCreator", fields: [createdById], references: [id])
  assignee  User?         @relation("TaskAssignee", fields: [assigneeId], references: [id])
  group     TeamGroup?    @relation(fields: [groupId], references: [id])
  comments  TaskComment[]

  @@index([listId])
  @@index([createdById])
  @@index([assigneeId])
  @@index([groupId])
  @@map("tasks")
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  userName  String
  text      String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_comments")
}

// ═══════════════════════════════════════════════
// TEAMS
// ═══════════════════════════════════════════════

model TeamGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  orgId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org     Organization?   @relation(fields: [orgId], references: [id])
  members TeamGroupMember[]
  tasks   Task[]

  @@index([orgId])
  @@map("team_groups")
}

model TeamGroupMember {
  id      String   @id @default(cuid())
  groupId String
  userId  String
  createdAt DateTime @default(now())

  group TeamGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId])
  @@map("team_group_members")
}

// ═══════════════════════════════════════════════
// CLIENTS & NEGOTIATIONS
// ═══════════════════════════════════════════════

model Client {
  id              String   @id @default(cuid())
  userId          String
  orgId           String?
  name            String
  brand           String   @default("STONE")
  safra           String   @default("M0")
  stoneCode       String   @default("")
  cnpj            String   @default("")
  phone           String   @default("")
  email           String   @default("")
  status          String   @default("ativo")
  credentialDate  String   @default("")
  cancelDate      String   @default("")
  segment         String   @default("")
  category        String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  org            Organization? @relation(fields: [orgId], references: [id])
  negotiations   Negotiation[]
  monthlyVolumes ClientMonth[]

  @@index([userId])
  @@index([orgId])
  @@map("clients")
}

model ClientMonth {
  id         String   @id @default(cuid())
  clientId   String
  month      String
  tpvDebit   Float    @default(0)
  tpvCredit  Float    @default(0)
  tpvPix     Float    @default(0)
  rateDebit  Float    @default(0)
  rateCredit Float    @default(0)
  ratePix    Float    @default(0)
  notes      String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, month])
  @@index([clientId])
  @@map("client_months")
}

model Negotiation {
  id                String   @id @default(cuid())
  clientId          String
  dateNeg           String
  dateAccept        String   @default("")
  status            String   @default("prospeccao")
  stageHistory      Json     @default("[]")
  assigneeId        String?
  rates             Json
  notes             String   @default("")
  alertDate         String   @default("")
  alertSent         Boolean  @default(false)
  
  simulatedTpv      Float    @default(0)
  machineRentExempt Boolean  @default(false)
  machinePurchase   Boolean  @default(false)
  machinesCount     Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignee User?  @relation("NegotiationAssignee", fields: [assigneeId], references: [id])
  comments NegotiationComment[]

  @@index([clientId])
  @@index([assigneeId])
  @@map("negotiations")
}

model NegotiationComment {
  id            String   @id @default(cuid())
  negotiationId String
  userId        String
  content       String
  createdAt     DateTime @default(now())

  negotiation Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@index([negotiationId])
  @@map("negotiation_comments")
}

// ═══════════════════════════════════════════════
// MISC
// ═══════════════════════════════════════════════

model Simulation {
  id        String   @id @default(cuid())
  userId    String
  name      String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares SimulationShare[]

  @@index([userId])
  @@map("simulations")
}

model SimulationShare {
  id           String   @id @default(cuid())
  simulationId String
  sharedWithId String
  createdAt    DateTime @default(now())

  simulation Simulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)
  sharedWith User       @relation(fields: [sharedWithId], references: [id], onDelete: Cascade)

  @@unique([simulationId, sharedWithId])
  @@map("simulation_shares")
}

model UserGoal {
  id            String   @id @default(cuid())
  userId        String
  month         String
  targetClients Int      @default(10)
  targetTPV     Float    @default(100000)
  targetDeals   Int      @default(15)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@map("user_goals")
}

model GoogleCalendarToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  calendarId   String   @default("primary")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_calendar_tokens")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  userName    String
  action      String
  entityType  String
  entityId    String?
  entityName  String?
  reason      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
